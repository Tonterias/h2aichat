# HumanIA Contract — Variables de entorno
# Copia este archivo a .env y configura los valores para tu entorno

# === REQUERIDO EN PRODUCCION ===
# Token de autenticacion para proteger la API
# Genera uno nuevo: python -c "import secrets; print(secrets.token_urlsafe(32))"
HUMANIA_TOKEN=cambiar-en-produccion

# Secreto de firma de los JWT de sesion (FASE 20.2)
# Genera uno nuevo: python -c "import secrets; print(secrets.token_urlsafe(32))"
HUMANIA_JWT_SECRET=cambiar-en-produccion

# Entorno: "dev" (localhost sin auth) o "production" (HTTPS + HSTS + token requerido)
HUMANIA_ENV=dev

# URL publica de la app (se usa en los enlaces de los emails)
HUMANIA_BASE_URL=http://localhost:8000

# === EMAIL TRANSACCIONAL (FASES 20.3/20.4/20.1) ===
# Backend: "console" (dev, imprime en consola), "resend" (produccion) o "smtp" (alternativa)
HUMANIA_EMAIL_BACKEND=console

# Backend resend (decision final PO 2026-06-11)
RESEND_API_KEY=
HUMANIA_EMAIL_FROM=hola@noreplay.h2aichat.com

# Backend smtp (alternativa, leccion 99)
# HUMANIA_SMTP_HOST=smtp.gmail.com
# HUMANIA_SMTP_PORT=587
# HUMANIA_SMTP_USER=
# HUMANIA_SMTP_PASS=

# === API KEYS PARA BOTS ===
# OpenCode Go API key (bots cloud por defecto)
OPENCODE_API_KEY=

# OpenRouter API key (alternativa para bots cloud)
OPENROUTER_API_KEY=

# === PUERTOS ===
# Puerto del servidor API (default: 8000)
# HUMANIA_PORT=8000

# Puerto del visor de BD (default: 8001, solo desarrollo)
# HUMANIA_DB_VIEWER_PORT=8001
